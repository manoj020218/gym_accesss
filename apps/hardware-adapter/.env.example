# URL of the local edge service (same RPi / mini PC)
EDGE_SERVICE_URL=http://localhost:8091

# Port for this adapter's own health endpoint
HEALTH_PORT=8092

# Path to the reader configuration file
READERS_CONFIG=./readers.config.json

# How long to hold the relay open on ALLOW (milliseconds)
RELAY_PULSE_MS=500

# Minimum gap between two reads of the same card (milliseconds)
CARD_COOLDOWN_MS=3000

# Set to 'true' to run without real GPIO hardware (generates simulated scans)
MOCK_MODE=false

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info
