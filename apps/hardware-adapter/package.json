{
  "name": "@edge-gym/hardware-adapter",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "GPIO/TCP bridge: reads RFID/QR hardware → calls edge service → controls relay",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev":   "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test":  "vitest run"
  },
  "dependencies": {
    "axios":         "^1.7.2",
    "fastify":       "^4.27.0",
    "onoff":         "^6.0.3",
    "serialport":    "^12.0.0",
    "@serialport/parser-delimiter": "^12.0.0",
    "zod":           "^3.23.8"
  },
  "devDependencies": {
    "@types/node":   "^20.14.0",
    "tsx":           "^4.15.0",
    "typescript":    "^5.4.5",
    "vitest":        "^1.6.0"
  }
}
