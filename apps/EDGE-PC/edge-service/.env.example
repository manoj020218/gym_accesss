NODE_ENV=development
LOG_LEVEL=info

EDGE_DEVICE_ID=DEV-XXXX-XXXXXXXX
EDGE_BRANCH_ID=<branch ObjectId from MongoDB>
EDGE_PORT=8090

EDGE_SYNC_BASE_URL=http://smartgym.iotsoft.in/api/v1/edge
EDGE_SHARED_SECRET=<from VPS api-server .env>

EDGE_SQLITE_PATH=./data/edge.db
EDGE_SYNC_INTERVAL_MS=30000
EDGE_HEARTBEAT_INTERVAL_MS=60000

# Primary U5 machine (seeded into DB on first boot if table is empty)
U5_MACHINE_IP=192.168.1.92
U5_MACHINE_PORT=80
U5_MACHINE_PASSWORD=123456

# How often to poll ALL registered machines for punch records (ms)
U5_POLL_INTERVAL_MS=30000

FACE_STORAGE_DIR=./storage/faces
EMPLOYEE_BACKUP_DIR=./storage/employees

# FRPC reverse tunnel — lets VPS reach this edge PC for remote enrollment
# FRPC_BINARY=C:\frp\frpc.exe
# FRPC_SERVER_ADDR=smartgym.iotsoft.in
# FRPC_SERVER_PORT=7000
# FRPC_TOKEN=<frps auth token>
# FRPC_SUBDOMAIN=edge-dev217c
