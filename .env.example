# ── Shared ────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ── API Server ────────────────────────────────────────────────────────────────
PORT=8080
MONGODB_URI=mongodb://localhost:27017/edge_gym
JWT_SECRET=replace_with_256bit_random_secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace_with_another_256bit_secret
REFRESH_TOKEN_EXPIRES_IN=30d
CORS_ORIGINS=http://localhost:5173,https://admin.edgegym.in

# Firebase (service account)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# FCM (for push notifications to owner/member apps)
FCM_SERVER_KEY=your_fcm_server_key

# Shared secret for HMAC signing of edge → VPS sync batches
# Must match EDGE_SHARED_SECRET in edge service .env
EDGE_SHARED_SECRET=replace_with_hmac_secret_min_16_chars

# ── Edge Service ──────────────────────────────────────────────────────────────
EDGE_DEVICE_ID=branch1-edge-01
EDGE_BRANCH_ID=branch_001
EDGE_PORT=8090
EDGE_SYNC_BASE_URL=https://api.edgegym.in/api/v1/edge
EDGE_SHARED_SECRET=replace_with_hmac_secret
EDGE_SQLITE_PATH=./data/edge.db
EDGE_SYNC_INTERVAL_MS=30000
EDGE_HEARTBEAT_INTERVAL_MS=60000
