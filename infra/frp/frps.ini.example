# =============================================================================
# FRPS — VPS side (smartgym.iotsoft.in)
# Copy to: /etc/frp/frps.ini
# Run:     pm2 start frps -- -c /etc/frp/frps.ini
# =============================================================================

[common]
bind_port    = 7000
token        = your_frp_token_here
dashboard_port = 7500
dashboard_user = admin
dashboard_pwd  = change_this_password
log_file       = /var/log/frps.log
log_level      = info
log_max_days   = 7
